{
  "name": "openpolpo",
  "version": "0.1.0",
  "description": "Agent-agnostic framework for orchestrating teams of AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./assessment": {
      "types": "./dist/assessment/index.d.ts",
      "import": "./dist/assessment/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    }
  },
  "bin": {
    "polpo": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "coding-agents",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openpolpo/openpolpo.git"
  },
  "homepage": "https://github.com/openpolpo/openpolpo",
  "bugs": {
    "url": "https://github.com/openpolpo/openpolpo/issues"
  },
  "author": "OpenPolpo Contributors",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@mariozechner/pi-agent-core": "^0.52.12",
    "@mariozechner/pi-ai": "^0.52.12",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sinclair/typebox": "^0.34.48",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "docx": "^9.5.3",
    "exceljs": "^4.4.0",
    "fullscreen-ink": "^0.1.0",
    "hono": "^4.11.9",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "mammoth": "^1.11.0",
    "nanoid": "^5.1.2",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "sox": "^0.1.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^7.0.10",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
