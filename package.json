{
  "name": "polpo-ai",
  "version": "0.3.11",
  "description": "The open-source platform for AI agent teams",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./assessment": {
      "types": "./dist/assessment/index.d.ts",
      "import": "./dist/assessment/index.js"
    }
  },
  "bin": {
    "polpo-ai": "dist/cli/index.js",
    "polpo": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "playbooks/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm --filter @polpo-ai/core build && pnpm --filter @polpo-ai/vault-crypto build && pnpm --filter @polpo-ai/drizzle build && tsc",
    "build:all": "./node_modules/.bin/tsc && pnpm --filter @polpo-ai/react build && pnpm --filter ui build",
    "build:sdk": "pnpm --filter @polpo-ai/react build",
    "build:ui": "pnpm --filter ui build",
    "dev": "tsc --watch",
    "dev:serve": "tsx --watch src/cli/index.ts serve -p 3890",
    "start:serve": "node dist/cli/index.js serve -p 3890",
    "dev:ui": "pnpm --filter ui dev",
    "dev:docs": "cd docs && npx mintlify@latest dev",
    "dev:all": "pnpm build:sdk && concurrently -n server,ui,docs -c blue,green,magenta \"pnpm dev:serve\" \"pnpm dev:ui\" \"pnpm dev:docs\"",
    "start": "node dist/cli/index.js",
    "start:all": "pnpm build:all && node dist/cli/index.js serve -p 3890",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm --filter @polpo-ai/core build && pnpm --filter @polpo-ai/drizzle build && ./node_modules/.bin/tsc --noEmit",
    "lint": "pnpm --filter ui lint",
    "clean": "rm -rf dist packages/react-sdk/dist ui/dist",
    "prepublishOnly": "./node_modules/.bin/tsc && pnpm build:sdk",
    "generate:openapi": "node -e \"const{createApp}=require('./dist/server/app.js');const app=createApp(null,null);const fs=require('fs');app.fetch(new Request('http://localhost/api/v1/openapi.json')).then(r=>r.json()).then(j=>{fs.writeFileSync('docs/openapi.json',JSON.stringify(j,null,2));console.log('Generated openapi.json with',Object.keys(j.paths).length,'paths')})\""
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "coding-agents",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumea-labs/polpo.git"
  },
  "homepage": "https://github.com/lumea-labs/polpo",
  "bugs": {
    "url": "https://github.com/lumea-labs/polpo/issues"
  },
  "author": "OpenPolpo Contributors",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.2",
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "@polpo-ai/core": "^0.3.9",
    "@polpo-ai/server": "^0.2.14",
    "@polpo-ai/vault-crypto": "^0.2.4",
    "@sinclair/typebox": "^0.34.48",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.6.1",
    "hono": "^4.11.9",
    "nanoid": "^5.1.2",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@polpo-ai/drizzle": "^0.2.10",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "docx": "^9.5.3",
    "drizzle-orm": "^0.44.0",
    "exceljs": "^4.4.0",
    "imapflow": "^1.2.10",
    "mammoth": "^1.11.0",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.52.0",
    "postgres": "^3.4.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^7.0.10",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "electron",
      "sharp",
      "@whiskeysockets/baileys",
      "protobufjs"
    ],
    "patchedDependencies": {
      "@radix-ui/react-popper@1.2.8": "patches/@radix-ui__react-popper@1.2.8.patch",
      "@radix-ui/react-slot@1.2.3": "patches/@radix-ui__react-slot@1.2.3.patch"
    }
  }
}
