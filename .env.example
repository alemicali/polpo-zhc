# ─────────────────────────────────────────────────────────────
# Polpo — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# Copy this file to .env (or .polpo/.env) and fill in the values you need.
# You can also set these as system environment variables.
#
# Provider API keys can also be configured via OAuth login:
#   polpo setup        (interactive wizard)
#   polpo auth login   (OAuth flow)
#
# Only uncomment the variables you need — everything is optional.
# ─────────────────────────────────────────────────────────────


# ── LLM Provider API Keys ───────────────────────────────────
# At least one provider is required. Set the key for your provider(s).
# Alternatively, use OAuth login (polpo setup) for supported providers.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...
# CEREBRAS_API_KEY=...
# XAI_API_KEY=xai-...
# OPENROUTER_API_KEY=sk-or-...
# MISTRAL_API_KEY=...
# HF_TOKEN=hf_...

# ── Cloud Platform Keys ─────────────────────────────────────

# AZURE_OPENAI_API_KEY=...
# AWS_ACCESS_KEY_ID=...           # Amazon Bedrock
# AWS_SECRET_ACCESS_KEY=...       # Amazon Bedrock
# GOOGLE_CLOUD_PROJECT=...        # Google Vertex AI

# ── Subscription-based Providers (OAuth recommended) ────────
# These providers work best via OAuth login (polpo setup).
# Manual keys are possible but OAuth is simpler.

# COPILOT_GITHUB_TOKEN=...        # GitHub Copilot

# ── Other LLM Providers ─────────────────────────────────────

# AI_GATEWAY_API_KEY=...          # Vercel AI Gateway
# ZAI_API_KEY=...
# MINIMAX_API_KEY=...
# MINIMAX_CN_API_KEY=...
# OPENCODE_API_KEY=...
# KIMI_API_KEY=...


# ── Polpo System Configuration ──────────────────────────────

# POLPO_MODEL=anthropic:claude-sonnet-4-5    # Default LLM model (provider:model)
# POLPO_JUDGE_MODEL=anthropic:claude-sonnet-4-5  # Model used for assessment/review
# POLPO_JUDGE_REASONING=medium               # Judge reasoning depth: minimal|low|medium|high|xhigh
# POLPO_STATE_DIR=/path/to/.polpo            # Custom state directory (must be absolute)
# POLPO_API_KEY=...                          # API key to protect the Polpo server
# POLPO_CORS_ORIGINS=http://localhost:3000   # Comma-separated allowed CORS origins
# POLPO_NO_UPDATE_CHECK=1                    # Disable CLI update checks


# ── Database (optional) ─────────────────────────────────────
# Only needed if using PostgreSQL storage (default is file-based).

# DATABASE_URL=postgresql://user:pass@localhost:5432/polpo


# ── Speech-to-Text (Voice Mode) ─────────────────────────────

# POLPO_STT_PROVIDER=deepgram        # STT provider: deepgram|groq|openai
# POLPO_STT_MODEL=nova-3             # Override STT model (provider-specific)
# POLPO_STT_LANG=auto                # Language code (ISO-639-1) or "auto"
# DEEPGRAM_API_KEY=...               # Required if STT provider is deepgram


# ── Text-to-Speech ──────────────────────────────────────────

# ELEVENLABS_API_KEY=...             # ElevenLabs TTS


# ── Image & Video Generation ────────────────────────────────

# FAL_KEY=...                        # fal.ai (image/video generation)


# ── Web Search ──────────────────────────────────────────────

# EXA_API_KEY=...                    # Exa AI semantic search


# ── Email (SMTP/IMAP) ───────────────────────────────────────
# For email tools and notifications via SMTP.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=...
# SMTP_FROM=you@gmail.com

# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=you@gmail.com
# IMAP_PASS=...


# ── Notifications ───────────────────────────────────────────
# Configured in polpo.json under "notifications", but tokens can go here.

# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...


# ── Security ────────────────────────────────────────────────
# Vault encryption key for credential storage (64 hex chars = 32 bytes).
# Auto-generated on first use. Set manually for CI/Docker deployments.

# POLPO_VAULT_KEY=...
