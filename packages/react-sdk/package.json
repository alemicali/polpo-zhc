{
  "name": "@openpolpo/react-sdk",
  "version": "0.1.0",
  "description": "React SDK for OpenPolpo — typed client + hooks with real-time SSE updates",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "files": ["dist", "README.md"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openpolpo/openpolpo.git",
    "directory": "packages/react-sdk"
  },
  "homepage": "https://github.com/openpolpo/openpolpo/tree/main/packages/react-sdk",
  "bugs": {
    "url": "https://github.com/openpolpo/openpolpo/issues"
  }
}
