{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Polpo",
  "theme": "mint",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo-dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#3B3E73",
    "light": "#8B8FD4",
    "dark": "#F78B97"
  },
  "fonts": {
    "heading": {
      "family": "Monaspace Argon",
      "source": "/fonts/MonaspaceArgon-Bold.woff",
      "format": "woff",
      "weight": 700
    },
    "body": {
      "family": "Monaspace Argon",
      "source": "/fonts/MonaspaceArgon-Regular.woff",
      "format": "woff",
      "weight": 400
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/openpolpo/openpolpo"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/openpolpo/openpolpo"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "getting-started",
              "guides/first-plan",
              "configuration"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/agents-and-teams",
              "concepts/task-lifecycle",
              "concepts/plans",
              "concepts/providers-and-models"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/tools-and-mcp",
              "features/skills",
              "features/workflows",
              "features/assessment",
              "features/hooks",
              "features/notifications",
              "features/approval-gates",
              "features/escalation",
              "features/scheduling",
              "features/bridge",
              "features/sessions",
              "features/memory",
              "features/deadlock-resolution",
              "features/question-detection",
              "features/resilience",
              "features/security",
              "features/writing-workflows"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "usage/cli",
              "usage/tui",
              "usage/server",
              "usage/web-ui"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/config",
              "reference/events",
              "reference/react-sdk",
              "reference/store-backends",
              "reference/coding-tools",
              {
                "group": "Extended Tools",
                "pages": [
                  "reference/tools/browser",
                  "reference/tools/git",
                  "reference/tools/http",
                  "reference/tools/multifile",
                  "reference/tools/deps",
                  "reference/tools/excel",
                  "reference/tools/pdf",
                  "reference/tools/docx",
                  "reference/tools/email",
                  "reference/tools/audio",
                  "reference/tools/image"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/openpolpo/openpolpo"
    }
  }
}
