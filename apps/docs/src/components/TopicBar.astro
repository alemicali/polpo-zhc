---
/**
 * Horizontal topic bar rendered below the sticky header.
 * Each topic corresponds to a docs section; clicking a topic navigates to its
 * landing page and the sidebar shows only that section's pages.
 */
import { topics, getActiveTopic } from './topic-map';

const currentPath = Astro.url.pathname;
const activeTopic = getActiveTopic(currentPath);
---

<nav class="topic-bar" aria-label="Documentation sections">
  <div class="topic-bar-inner">
    {topics.map((t) => (
      <a
        href={t.href}
        class:list={["topic-link", { active: activeTopic === t }]}
        aria-current={activeTopic === t ? "true" : undefined}
      >
        {t.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .topic-bar {
    background-color: color-mix(in oklab, var(--background, var(--color-background)) 60%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--border, var(--color-border-weak, #e5e5e5)) 40%, transparent);
    width: 100%;
    z-index: 40;
    position: sticky;
    top: 3.5rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  :global([data-theme='dark']) .topic-bar {
    border-color: var(--border, var(--color-border-weak));
  }

  .topic-bar-inner {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    max-width: 1680px;
    margin: 0 auto;
    padding: 0 1.5rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .topic-bar-inner::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .topic-bar-inner {
      padding: 0 2rem;
    }
  }

  @media (min-width: 1800px) {
    .topic-bar-inner {
      padding: 0 3rem;
    }
  }

  .topic-link {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    color: var(--muted-foreground, var(--color-text-weak, #888)) !important;
    text-decoration: none !important;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .topic-link:hover {
    color: var(--accent-foreground, var(--foreground, var(--color-text-strong, #111))) !important;
  }

  .topic-link.active {
    color: var(--accent-foreground, var(--foreground, var(--color-text-strong, #111))) !important;
    border-bottom-color: var(--accent-foreground, var(--foreground, var(--color-text-strong, #111)));
    font-weight: 600;
  }
</style>
